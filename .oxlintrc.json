{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-useless-spread": "warn",
    "no-useless-fallback-in-spread": "warn",
    "no-new-array": "warn",
    "no-this-alias": "warn",
    "no-underscore-dangle": "warn"
  },
  "env": {
    "builtin": true
  }
}
